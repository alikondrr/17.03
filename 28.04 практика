        public class Movie
        {
            private string _name;
            private int[] _stars;
            public string Name => _name;
            public int[] Stars => _stars.ToArray();

            public Movie(string name)
            {
                _name = name;
                _stars = new int[0];
            }

            public void Add(int star) {
                Array.Resize(ref _stars, _stars.Length + 1);
                _stars[_stars.Length - 1] = star;
            }


        }



